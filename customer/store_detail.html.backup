<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>店铺详情 - 振华商城</title>
<script src="https://cdn.tailwindcss.com?plugins=forms"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script>tailwind.config={theme:{extend:{colors:{"primary":"#a04100","primary-container":"#ff6b00","on-primary":"#ffffff","surface":"#f9f9f9","on-surface":"#1a1c1c","secondary":"#5f5e5e"}}}}</script>
<style>
  body{font-family:'Work Sans',sans-serif;background:#f9f9f9;min-height:100dvh;}
  .material-symbols-outlined{font-variation-settings:'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24;}
</style>
</head>
<body class="bg-surface text-on-surface pb-24">

<!-- Header -->
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur shadow-sm flex items-center px-4 h-14">
  <button onclick="history.back()" class="p-2 -ml-2">
    <span class="material-symbols-outlined text-primary">arrow_back</span>
  </button>
  <h1 class="flex-1 text-center font-bold text-on-surface" id="store-name">店铺详情</h1>
  <button id="lang-toggle" onclick="I18N.toggle()" class="w-8 h-8 rounded-full bg-orange-50 border border-orange-200 text-primary font-bold text-xs">EN</button>
</header>

<main id="store-content" class="pb-4"></main>

<!-- 底部导航 -->
<nav class="fixed bottom-0 left-0 w-full flex justify-around items-center px-2 py-2 bg-white/95 backdrop-blur border-t border-orange-50 shadow-lg z-50" id="customer-bottom-nav"></nav>

<script src="../db.js"></script>
<script src="_nav.js"></script>
<script>
  DB.init();
  I18N.applyAll();
  
  const user = DB.getCurrentUser();
  if (!user) {
    window.location.href = 'login.html';
  }
  
  renderCustomerNav('stores');
  updateCartBadge();

  // 获取店铺ID
  const urlParams = new URLSearchParams(window.location.search);
  const storeId = parseInt(urlParams.get('id'));
  const store = DB.findById('stores', storeId);

  if (!store) {
    document.getElementById('store-content').innerHTML = `
      <div class="text-center py-20 text-secondary">
        <span class="material-symbols-outlined text-6xl text-gray-200">store</span>
        <p class="mt-3">${I18N.t('店铺不存在','Store not found')}</p>
      </div>`;
  } else {
    document.getElementById('store-name').textContent = I18N.t(store.name_zh, store.name_en);
    
    // 获取该店铺的商品（按store_id筛选）
    const products = DB.findAll('products').filter(p => p.store_id === storeId && p.status === 'on_sale');
    
    document.getElementById('store-content').innerHTML = `
      <!-- 店铺封面 -->
      <div class="relative h-48 overflow-hidden">
        <img src="${store.image || 'https://via.placeholder.com/400x200'}" class="w-full h-full object-cover"/>
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
      </div>

      <div class="px-4 -mt-8 relative z-10">
        <!-- 店铺信息卡片 -->
        <div class="bg-white rounded-2xl p-5 shadow-lg border border-orange-50">
          <h2 class="font-black text-xl text-on-surface">${I18N.t(store.name_zh, store.name_en)}</h2>
          <p class="text-xs text-secondary mt-1">${store.category}</p>
          
          <div class="flex items-center gap-4 mt-4">
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings:'FILL' 1,'wght' 500">star</span>
              <span class="font-bold text-on-surface">${store.rating}</span>
              <span class="text-xs text-secondary">(${store.review_count}+ ${I18N.t('评价','reviews')})</span>
            </div>
          </div>

          <div class="mt-4 space-y-2">
            <div class="flex items-start gap-2 text-sm">
              <span class="material-symbols-outlined text-secondary text-xl">location_on</span>
              <span class="text-secondary flex-1">${store.address}</span>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <span class="material-symbols-outlined text-secondary text-xl">schedule</span>
              <span class="text-secondary">${I18N.t('营业时间','Hours')}: ${store.open_hours}</span>
            </div>
          </div>
        </div>

        <!-- 店铺商品 -->
        <div class="mt-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-bold text-on-surface text-lg border-l-4 border-primary pl-3">${I18N.t('店铺商品','Store Products')}</h3>
            <span class="text-xs text-secondary">${products.length} ${I18N.t('件商品','items')}</span>
          </div>
          
          ${products.length === 0 ? `
            <div class="text-center py-10 text-secondary text-sm">
              ${I18N.t('该店铺暂无商品','No products available')}
            </div>
          ` : `
            <div class="space-y-8">
              ${products.map((p, idx) => `
                <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-orange-50">
                  <!-- Hero Product Image -->
                  <div class="relative w-full aspect-square overflow-hidden">
                    <img src="${p.image || 'https://via.placeholder.com/400'}" class="w-full h-full object-cover" alt="${p.name_zh}"/>
                    ${p.stock <= 5 ? `<div class="absolute top-3 left-3 bg-red-500/90 text-white text-xs px-3 py-1 rounded-full font-bold">${I18N.t('仅剩','Only')} ${p.stock}</div>` : ''}
                    ${p.points_reward > 0 ? `<div class="absolute top-3 right-3 bg-amber-400/90 text-white text-xs px-3 py-1 rounded-full font-bold">+${p.points_reward}${I18N.t('积分','pts')}</div>` : ''}
                  </div>

                  <!-- Product Content -->
                  <div class="p-4">
                    <div class="flex justify-between items-start">
                      <div class="flex-1">
                        <span class="inline-block px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-bold mb-2">${I18N.t('精品推荐','Featured')}</span>
                        <h3 class="font-bold text-lg text-on-surface">${I18N.t(p.name_zh, p.name_en)}</h3>
                      </div>
                      <div class="text-right">
                        <p class="font-black text-2xl text-primary">¥${p.price}</p>
                      </div>
                    </div>

                    ${p.variants ? `
                      <!-- Color Selection -->
                      ${p.variants.colors ? `
                        <div class="mt-4 pt-4 border-t border-gray-100">
                          <h4 class="font-semibold text-sm text-on-surface mb-3">${I18N.t('颜色','Color')}</h4>
                          <div class="flex gap-3">
                            ${p.variants.colors.map((color, cidx) => `
                              <button onclick="selectColor(${p.id}, ${cidx})" 
                                      id="color-${p.id}-${cidx}"
                                      class="w-12 h-12 rounded-full border-2 ${cidx === 0 ? 'border-primary-container' : 'border-transparent'} p-0.5 active:scale-90 transition-all">
                                <div class="w-full h-full rounded-full" style="background-color: ${color.value}"></div>
                              </button>
                            `).join('')}
                          </div>
                        </div>
                      ` : ''}

                      <!-- Size Selection -->
                      ${p.variants.sizes ? `
                        <div class="mt-4">
                          <h4 class="font-semibold text-sm text-on-surface mb-3">${I18N.t('尺寸','Size')}</h4>
                          <div class="flex flex-wrap gap-2">
                            ${p.variants.sizes.map((size, sidx) => `
                              <button onclick="selectSize(${p.id}, ${sidx})" 
                                      id="size-${p.id}-${sidx}"
                                      class="px-5 py-2 rounded-lg border ${sidx === 0 ? 'bg-primary-container text-white border-primary-container font-bold' : 'border-gray-300 text-on-surface'} text-sm active:scale-95 transition-all">
                                ${size}
                              </button>
                            `).join('')}
                          </div>
                        </div>
                      ` : ''}

                      <!-- Delivery Method -->
                      <div class="mt-4">
                        <h4 class="font-semibold text-sm text-on-surface mb-3">${I18N.t('配送方式','Delivery Method')}</h4>
                        <div class="grid grid-cols-2 gap-3">
                          <button onclick="selectDelivery(${p.id}, 'home')" 
                                  id="delivery-${p.id}-home"
                                  class="flex flex-col items-center justify-center p-3 rounded-xl border-2 border-primary-container bg-primary/5 active:scale-95 transition-all">
                            <span class="material-symbols-outlined text-primary mb-1">local_shipping</span>
                            <span class="text-xs font-bold text-primary">${I18N.t('快递到家','Home Delivery')}</span>
                          </button>
                          <button onclick="selectDelivery(${p.id}, 'pickup')" 
                                  id="delivery-${p.id}-pickup"
                                  class="flex flex-col items-center justify-center p-3 rounded-xl border-2 border-gray-300 active:scale-95 transition-all">
                            <span class="material-symbols-outlined text-secondary mb-1">storefront</span>
                            <span class="text-xs text-secondary">${I18N.t('到店自提','Store Pickup')}</span>
                          </button>
                        </div>
                      </div>
                    ` : ''}

                    <!-- Quantity Selector -->
                    <div class="mt-4 ${p.variants ? '' : 'pt-4 border-t border-gray-100'} flex items-center justify-between">
                      <span class="font-semibold text-sm text-secondary">${I18N.t('数量','Quantity')}</span>
                      <div class="flex items-center bg-gray-50 rounded-full p-1 border border-gray-200">
                        <button onclick="changeQty(${p.id}, -1)" class="w-8 h-8 flex items-center justify-center text-secondary active:scale-90 transition-transform">
                          <span class="material-symbols-outlined text-lg">remove</span>
                        </button>
                        <span id="qty-${p.id}" class="w-10 text-center font-bold text-on-surface">1</span>
                        <button onclick="changeQty(${p.id}, 1)" class="w-8 h-8 flex items-center justify-center text-primary active:scale-90 transition-transform">
                          <span class="material-symbols-outlined text-lg">add</span>
                        </button>
                      </div>
                    </div>

                    <!-- Product Description -->
                    <div class="mt-5">
                      <h4 class="font-bold text-sm mb-3 border-l-4 border-primary pl-2">${I18N.t('商品详情','Product Details')}</h4>
                      <p class="text-sm text-secondary leading-relaxed">${I18N.t(p.description_zh || p.name_zh + '，优质商品，值得信赖。', p.description_en || p.name_en + ', quality product you can trust.')}</p>
                      
                      <!-- Detail Cards -->
                      ${store.category === 'Coffee' ? `
                        <div class="grid grid-cols-2 gap-3 mt-4">
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">coffee</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('中浅烘焙','Medium Roast')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('保留明亮酸质','Bright acidity')}</p>
                          </div>
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">thermostat</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('92°C 恒温','92°C Constant')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('精准水温萃取','Precise extraction')}</p>
                          </div>
                        </div>
                      ` : store.category === 'Bakery' ? `
                        <div class="grid grid-cols-2 gap-3 mt-4">
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">bakery_dining</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('新鲜出炉','Freshly Baked')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('每日现做','Made daily')}</p>
                          </div>
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">verified</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('优质原料','Premium Ingredients')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('精选食材','Selected materials')}</p>
                          </div>
                        </div>
                      ` : store.category === 'Electronics' ? `
                        <div class="grid grid-cols-2 gap-3 mt-4">
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">verified_user</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('正品保证','Authentic')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('官方授权','Official')}</p>
                          </div>
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">support_agent</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('售后保障','Warranty')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('一年质保','1-year')}</p>
                          </div>
                        </div>
                      ` : store.category === 'Fashion' ? `
                        <div class="grid grid-cols-2 gap-3 mt-4">
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">local_shipping</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('快速配送','Fast Delivery')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('48小时送达','48h delivery')}</p>
                          </div>
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">autorenew</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('7天退换','7-Day Return')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('无忧退换','Easy return')}</p>
                          </div>
                        </div>
                      ` : store.category === 'Beauty' ? `
                        <div class="grid grid-cols-2 gap-3 mt-4">
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">workspace_premium</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('专业服务','Professional')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('资深美容师','Expert staff')}</p>
                          </div>
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">spa</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('舒适环境','Relaxing')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('私密空间','Private room')}</p>
                          </div>
                        </div>
                      ` : `
                        <div class="grid grid-cols-2 gap-3 mt-4">
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">eco</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('新鲜直供','Fresh Supply')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('当日采购','Daily sourced')}</p>
                          </div>
                          <div class="bg-orange-50 p-3 rounded-xl border border-orange-100">
                            <span class="material-symbols-outlined text-primary mb-2 block">health_and_safety</span>
                            <p class="font-bold text-xs text-on-surface">${I18N.t('品质保证','Quality Assured')}</p>
                            <p class="text-[10px] text-secondary opacity-70">${I18N.t('安全可靠','Safe & reliable')}</p>
                          </div>
                        </div>
                      `}
                    </div>

                    <!-- Secondary Images (Bento Style) -->
                    ${idx === 0 && store.category === 'Coffee' ? `
                      <div class="mt-5 grid grid-cols-2 gap-3">
                        <div class="rounded-xl overflow-hidden shadow-sm h-40">
                          <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=400&h=300&fit=crop" alt="Coffee brewing"/>
                        </div>
                        <div class="rounded-xl overflow-hidden shadow-sm h-40">
                          <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=400&h=300&fit=crop" alt="Coffee cup"/>
                        </div>
                      </div>
                    ` : ''}

                    <!-- Add to Cart Button -->
                    <button onclick="addToCartWithQty(${p.id})" class="w-full mt-5 bg-primary-container hover:bg-primary text-white font-bold py-3 rounded-xl flex items-center justify-center gap-2 active:scale-95 transition-all shadow-md">
                      <span class="material-symbols-outlined">shopping_cart</span>
                      <span>${I18N.t('加入购物车','Add to Cart')}</span>
                    </button>
                  </div>
                </div>
              `).join('')}
            </div>
          `}
        </div>
      </div>
    `;
  }

  // 数量管理
  const quantities = {};
  const selections = {}; // 存储每个产品的选择：颜色、尺寸、配送方式
  
  function changeQty(productId, delta) {
    if (!quantities[productId]) quantities[productId] = 1;
    quantities[productId] = Math.max(1, Math.min(99, quantities[productId] + delta));
    const qtyEl = document.getElementById('qty-' + productId);
    if (qtyEl) qtyEl.textContent = quantities[productId];
  }

  function selectColor(productId, colorIndex) {
    if (!selections[productId]) selections[productId] = {};
    selections[productId].colorIndex = colorIndex;
    
    // 更新UI
    const product = DB.findById('products', productId);
    if (product && product.variants && product.variants.colors) {
      product.variants.colors.forEach((_, idx) => {
        const btn = document.getElementById(`color-${productId}-${idx}`);
        if (btn) {
          if (idx === colorIndex) {
            btn.classList.remove('border-transparent');
            btn.classList.add('border-primary-container');
          } else {
            btn.classList.remove('border-primary-container');
            btn.classList.add('border-transparent');
          }
        }
      });
    }
  }

  function selectSize(productId, sizeIndex) {
    if (!selections[productId]) selections[productId] = {};
    selections[productId].sizeIndex = sizeIndex;
    
    // 更新UI
    const product = DB.findById('products', productId);
    if (product && product.variants && product.variants.sizes) {
      product.variants.sizes.forEach((_, idx) => {
        const btn = document.getElementById(`size-${productId}-${idx}`);
        if (btn) {
          if (idx === sizeIndex) {
            btn.classList.add('bg-primary-container', 'text-white', 'border-primary-container', 'font-bold');
            btn.classList.remove('border-gray-300', 'text-on-surface');
          } else {
            btn.classList.remove('bg-primary-container', 'text-white', 'border-primary-container', 'font-bold');
            btn.classList.add('border-gray-300', 'text-on-surface');
          }
        }
      });
    }
  }

  function selectDelivery(productId, method) {
    if (!selections[productId]) selections[productId] = {};
    selections[productId].delivery = method;
    
    // 更新UI
    const homeBtn = document.getElementById(`delivery-${productId}-home`);
    const pickupBtn = document.getElementById(`delivery-${productId}-pickup`);
    
    if (method === 'home') {
      if (homeBtn) {
        homeBtn.classList.add('border-primary-container', 'bg-primary/5');
        homeBtn.classList.remove('border-gray-300');
        homeBtn.querySelector('span.material-symbols-outlined').classList.add('text-primary');
        homeBtn.querySelector('span.material-symbols-outlined').classList.remove('text-secondary');
        homeBtn.querySelector('span:last-child').classList.add('text-primary', 'font-bold');
        homeBtn.querySelector('span:last-child').classList.remove('text-secondary');
      }
      if (pickupBtn) {
        pickupBtn.classList.remove('border-primary-container', 'bg-primary/5');
        pickupBtn.classList.add('border-gray-300');
        pickupBtn.querySelector('span.material-symbols-outlined').classList.remove('text-primary');
        pickupBtn.querySelector('span.material-symbols-outlined').classList.add('text-secondary');
        pickupBtn.querySelector('span:last-child').classList.remove('text-primary', 'font-bold');
        pickupBtn.querySelector('span:last-child').classList.add('text-secondary');
      }
    } else {
      if (pickupBtn) {
        pickupBtn.classList.add('border-primary-container', 'bg-primary/5');
        pickupBtn.classList.remove('border-gray-300');
        pickupBtn.querySelector('span.material-symbols-outlined').classList.add('text-primary');
        pickupBtn.querySelector('span.material-symbols-outlined').classList.remove('text-secondary');
        pickupBtn.querySelector('span:last-child').classList.add('text-primary', 'font-bold');
        pickupBtn.querySelector('span:last-child').classList.remove('text-secondary');
      }
      if (homeBtn) {
        homeBtn.classList.remove('border-primary-container', 'bg-primary/5');
        homeBtn.classList.add('border-gray-300');
        homeBtn.querySelector('span.material-symbols-outlined').classList.remove('text-primary');
        homeBtn.querySelector('span.material-symbols-outlined').classList.add('text-secondary');
        homeBtn.querySelector('span:last-child').classList.remove('text-primary', 'font-bold');
        homeBtn.querySelector('span:last-child').classList.add('text-secondary');
      }
    }
  }

  function addToCartWithQty(productId) {
    let currentUser = DB.getCurrentUser();
    if (!currentUser) {
      const guestPhone = 'guest_' + Date.now();
      currentUser = DB.registerUser(guestPhone, 'guest123', I18N.t('游客用户', 'Guest User'));
    }
    
    const product = DB.findById('products', productId);
    const qty = quantities[productId] || 1;
    const selection = selections[productId] || {};
    
    // 构建规格字符串
    let spec = '';
    if (product && product.variants) {
      const parts = [];
      if (product.variants.colors && selection.colorIndex !== undefined) {
        const color = product.variants.colors[selection.colorIndex];
        parts.push(I18N.t(color.name_zh, color.name_en));
      }
      if (product.variants.sizes && selection.sizeIndex !== undefined) {
        parts.push(product.variants.sizes[selection.sizeIndex]);
      }
      if (selection.delivery) {
        parts.push(selection.delivery === 'home' ? I18N.t('快递到家', 'Home Delivery') : I18N.t('到店自提', 'Store Pickup'));
      }
      spec = parts.join(' / ');
    }
    
    for (let i = 0; i < qty; i++) {
      DB.addToCart(currentUser.id, productId, 1, spec);
    }
    
    updateCartBadge();
    
    // 视觉反馈
    const btn = event.target.closest('button');
    const originalText = btn.innerHTML;
    btn.innerHTML = `<span class="material-symbols-outlined">check_circle</span><span>${I18N.t('已添加','Added')}</span>`;
    btn.classList.add('bg-green-500');
    setTimeout(() => {
      btn.innerHTML = originalText;
      btn.classList.remove('bg-green-500');
    }, 1000);
  }
</script>
</body>
</html>
